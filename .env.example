# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=           # e.g. https://your-search.search.windows.net
AZURE_SEARCH_KEY=                # Admin or query key from Azure portal

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=           # e.g. https://your-openai.openai.azure.com/
AZURE_OPENAI_KEY=                # API key from Azure OpenAI resource

# ── Model deployment names (match your Azure OpenAI deployments) ──────────────
EMBEDDING_DEPLOYMENT=text-embedding-3-large
GPT4O_DEPLOYMENT=gpt-4o
GPT4O_MINI_DEPLOYMENT=gpt-4o-mini

# ── Google Custom Search Engine ───────────────────────────────────────────────
GOOGLE_CSE_API_KEY=              # Google API key (or comma-separated list for rotation)
GOOGLE_CSE_ID=                   # Custom Search Engine ID (cx parameter)
